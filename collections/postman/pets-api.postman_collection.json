        {
          "name": "Atualizar veterinario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Dra. Marina Lima\",\n  \"crmv\": \"CRMV-SP-12345\",\n  \"especialidade\": \"Dermatologia\",\n  \"telefone\": \"1133335555\",\n  \"email\": \"marina@clinica.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/veterinarios/{{veterinarioId}}"
