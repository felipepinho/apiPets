    },
    {
      "name": "Vacinas",
      "item": [
        {
          "name": "Criar vacina do pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('vacinaId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Raiva\",\n  \"dataAplicacao\": \"2026-05-19\",\n  \"dataProximaDose\": \"2027-05-19\",\n  \"veterinarioId\": {{veterinarioId}},\n  \"observacao\": \"Aplicacao anual\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/pets/{{petId}}/vacinas"
          }
        },
        { "name": "Listar vacinas do pet", "request": { "method": "GET", "url": "{{baseUrl}}/pets/{{petId}}/vacinas" } },
        { "name": "Buscar vacina por id", "request": { "method": "GET", "url": "{{baseUrl}}/vacinas/{{vacinaId}}" } },
        {
          "name": "Atualizar vacina",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Raiva\",\n  \"dataAplicacao\": \"2026-05-19\",\n  \"dataProximaDose\": \"2027-05-19\",\n  \"veterinarioId\": {{veterinarioId}},\n  \"observacao\": \"Aplicacao anual atualizada\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/vacinas/{{vacinaId}}"
          }
        },
        { "name": "Excluir vacina", "request": { "method": "DELETE", "url": "{{baseUrl}}/vacinas/{{vacinaId}}" } }
      ]
    },
    {
      "name": "Consultas",
      "item": [
        {
          "name": "Criar consulta",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('consultaId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"petId\": {{petId}},\n  \"veterinarioId\": {{veterinarioId}},\n  \"dataHora\": \"2026-05-20T14:30:00\",\n  \"motivo\": \"Consulta de rotina\",\n  \"diagnostico\": null,\n  \"observacoes\": \"Tutor relatou boa alimentacao\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/consultas"
          }
        },
        { "name": "Listar consultas", "request": { "method": "GET", "url": "{{baseUrl}}/consultas" } },
        { "name": "Buscar consulta por id", "request": { "method": "GET", "url": "{{baseUrl}}/consultas/{{consultaId}}" } },
        {
          "name": "Atualizar consulta",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"petId\": {{petId}},\n  \"veterinarioId\": {{veterinarioId}},\n  \"dataHora\": \"2026-05-20T15:30:00\",\n  \"motivo\": \"Consulta de retorno\",\n  \"diagnostico\": \"Sem alteracoes\",\n  \"observacoes\": \"Retorno em 30 dias\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/consultas/{{consultaId}}"
          }
        },
        {
          "name": "Atualizar status da consulta",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"REALIZADA\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/consultas/{{consultaId}}/status"
          }
        },
        { "name": "Listar consultas por pet", "request": { "method": "GET", "url": "{{baseUrl}}/consultas/pet/{{petId}}" } },
        { "name": "Listar consultas por veterinario", "request": { "method": "GET", "url": "{{baseUrl}}/consultas/veterinario/{{veterinarioId}}" } },
        { "name": "Excluir consulta", "request": { "method": "DELETE", "url": "{{baseUrl}}/consultas/{{consultaId}}" } }
      ]
    },
    {
      "name": "Historico Medico",
