{
  "info": {
    "name": "Pets API",
    "description": "Collection para testar a API de gerenciamento de pets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tutorId", "value": "1" },
    { "key": "petId", "value": "1" },
    { "key": "veterinarioId", "value": "1" },
    { "key": "vacinaId", "value": "1" },
    { "key": "consultaId", "value": "1" },
    { "key": "historicoId", "value": "1" }
  ],
  "item": [
    {
      "name": "Tutores",
      "item": [
        {
          "name": "Criar tutor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('tutorId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Ana Souza\",\n  \"email\": \"ana@email.com\",\n  \"telefone\": \"11999999999\",\n  \"cpf\": \"12345678900\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tutores"
          }
        },
        { "name": "Listar tutores", "request": { "method": "GET", "url": "{{baseUrl}}/tutores" } },
        { "name": "Buscar tutor por id", "request": { "method": "GET", "url": "{{baseUrl}}/tutores/{{tutorId}}" } },
        {
          "name": "Atualizar tutor",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Ana Souza Atualizada\",\n  \"email\": \"ana.atualizada@email.com\",\n  \"telefone\": \"11988887777\",\n  \"cpf\": \"12345678900\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tutores/{{tutorId}}"
          }
        },
        { "name": "Listar pets do tutor", "request": { "method": "GET", "url": "{{baseUrl}}/tutores/{{tutorId}}/pets" } },
        { "name": "Excluir tutor", "request": { "method": "DELETE", "url": "{{baseUrl}}/tutores/{{tutorId}}" } }
      ]
    },
    {
      "name": "Pets",
      "item": [
        {
          "name": "Criar pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('petId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Thor\",\n  \"especie\": \"Cachorro\",\n  \"raca\": \"Golden Retriever\",\n  \"idade\": 4,\n  \"peso\": 28.5,\n  \"sexo\": \"MACHO\",\n  \"castrado\": true,\n  \"tutorId\": {{tutorId}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/pets"
          }
        },
        { "name": "Listar pets", "request": { "method": "GET", "url": "{{baseUrl}}/pets" } },
        { "name": "Buscar pet por id", "request": { "method": "GET", "url": "{{baseUrl}}/pets/{{petId}}" } },
        {
          "name": "Atualizar pet",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Thor Atualizado\",\n  \"especie\": \"Cachorro\",\n  \"raca\": \"Golden Retriever\",\n  \"idade\": 5,\n  \"peso\": 30.0,\n  \"sexo\": \"MACHO\",\n  \"castrado\": true,\n  \"tutorId\": {{tutorId}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/pets/{{petId}}"
          }
        },
        {
          "name": "Atualizar pet parcialmente",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"peso\": 31.2,\n  \"castrado\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/pets/{{petId}}"
          }
        },
        { "name": "Listar pets por tutor", "request": { "method": "GET", "url": "{{baseUrl}}/pets/tutor/{{tutorId}}" } },
        { "name": "Excluir pet", "request": { "method": "DELETE", "url": "{{baseUrl}}/pets/{{petId}}" } }
      ]
    },
