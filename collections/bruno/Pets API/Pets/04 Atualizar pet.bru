meta {
  name: Atualizar pet
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/pets/{{petId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "nome": "Thor Atualizado",
    "especie": "Cachorro",
    "raca": "Golden Retriever",
    "idade": 5,
    "peso": 30.0,
    "sexo": "MACHO",
    "castrado": true,
    "tutorId": {{tutorId}}
  }
}
