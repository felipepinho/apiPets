meta {
  name: Criar vacina do pet
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/pets/{{petId}}/vacinas
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "nome": "Raiva",
    "dataAplicacao": "2026-05-19",
    "dataProximaDose": "2027-05-19",
    "veterinarioId": {{veterinarioId}},
    "observacao": "Aplicacao anual"
  }
}
