meta {
  name: Atualizar vacina
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/vacinas/{{vacinaId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "nome": "Raiva",
    "dataAplicacao": "2026-05-19",
    "dataProximaDose": "2027-05-19",
    "veterinarioId": {{veterinarioId}},
    "observacao": "Aplicacao anual atualizada"
  }
}
